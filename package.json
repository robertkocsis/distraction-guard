    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "svelte": "^5.53.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-web-extension": "^4.5.0",
    "vitest": "^4.0.18"
